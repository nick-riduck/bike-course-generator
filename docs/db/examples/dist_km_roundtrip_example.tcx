<?xml version="1.0" encoding="UTF-8"?>
<TrainingCenterDatabase
  xmlns="http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2"
  xmlns:riduck="https://riduck.dev/xmlns/1">
  <Courses>
    <Course>
      <Name>dist_km_roundtrip_example</Name>
      <Lap>
        <TotalTimeSeconds>900.0</TotalTimeSeconds>
        <DistanceMeters>5000.0</DistanceMeters>
      </Lap>

      <Track>
        <Trackpoint>
          <Time>2026-02-24T10:00:00Z</Time>
          <Position>
            <LatitudeDegrees>37.500000</LatitudeDegrees>
            <LongitudeDegrees>127.000000</LongitudeDegrees>
          </Position>
          <AltitudeMeters>10.0</AltitudeMeters>
          <DistanceMeters>0.0</DistanceMeters>
        </Trackpoint>
        <Trackpoint>
          <Time>2026-02-24T10:07:30Z</Time>
          <Position>
            <LatitudeDegrees>37.505000</LatitudeDegrees>
            <LongitudeDegrees>127.005000</LongitudeDegrees>
          </Position>
          <AltitudeMeters>35.0</AltitudeMeters>
          <DistanceMeters>2500.0</DistanceMeters>
        </Trackpoint>
        <Trackpoint>
          <Time>2026-02-24T10:15:00Z</Time>
          <Position>
            <LatitudeDegrees>37.510000</LatitudeDegrees>
            <LongitudeDegrees>127.010000</LongitudeDegrees>
          </Position>
          <AltitudeMeters>80.0</AltitudeMeters>
          <DistanceMeters>5000.0</DistanceMeters>
        </Trackpoint>
      </Track>

      <CoursePoint>
        <Name>Warmup</Name>
        <Time>2026-02-24T10:00:00Z</Time>
        <Position>
          <LatitudeDegrees>37.500000</LatitudeDegrees>
          <LongitudeDegrees>127.000000</LongitudeDegrees>
        </Position>
        <PointType>Generic</PointType>
        <Notes>Riduck_Section:Color=#00ff00;Riduck_DistKm=0.000000</Notes>
        <Extensions>
          <riduck:dist_km>0.000000</riduck:dist_km>
        </Extensions>
      </CoursePoint>

      <CoursePoint>
        <Name>Aid</Name>
        <Time>2026-02-24T10:07:30Z</Time>
        <Position>
          <LatitudeDegrees>37.505000</LatitudeDegrees>
          <LongitudeDegrees>127.005000</LongitudeDegrees>
        </Position>
        <PointType>Generic</PointType>
        <Notes>Riduck_DistKm=2.500000</Notes>
        <Extensions>
          <riduck:dist_km>2.500000</riduck:dist_km>
        </Extensions>
      </CoursePoint>

      <CoursePoint>
        <Name>Main Climb</Name>
        <Time>2026-02-24T10:15:00Z</Time>
        <Position>
          <LatitudeDegrees>37.510000</LatitudeDegrees>
          <LongitudeDegrees>127.010000</LongitudeDegrees>
        </Position>
